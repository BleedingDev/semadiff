{
	"name": "@semadiff/cli",
	"version": "0.1.0",
	"bin": {
		"semadiff": "dist/index.js"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "tsc -b tsconfig.build.json"
	},
	"dependencies": {
		"@effect/platform-node": "4.0.0-beta.5",
		"@effect/platform-node-shared": "4.0.0-beta.5",
		"@semadiff/core": "workspace:*",
		"@semadiff/entity-core": "workspace:*",
		"@semadiff/parser-lightningcss": "workspace:*",
		"@semadiff/parser-swc": "workspace:*",
		"@semadiff/parser-tree-sitter-wasm": "workspace:*",
		"@semadiff/parsers": "workspace:*",
		"@semadiff/pr-backend": "workspace:*",
		"@semadiff/render-html": "workspace:*",
		"@semadiff/render-terminal": "workspace:*",
		"effect": "4.0.0-beta.5"
	},
	"devDependencies": {
		"@types/node": "^20.14.15"
	}
}
