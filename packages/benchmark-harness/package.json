{
	"name": "@semadiff/benchmark-harness",
	"version": "0.1.0",
	"files": [
		"dist"
	],
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"benchmark": "node dist/cli.js --cases ../../bench/cases/gold/micro",
		"review-guide-benchmark": "node dist/cli.js --mode review-guide --cases ../../bench/cases/real/prs"
	},
	"dependencies": {
		"@semadiff/core": "workspace:*",
		"@semadiff/entity-core": "workspace:*",
		"@semadiff/parser-swc": "workspace:*",
		"@semadiff/render-html": "workspace:*",
		"@semadiff/review-guide": "workspace:*",
		"effect": "4.0.0-beta.5"
	},
	"devDependencies": {
		"@types/node": "^20.14.15"
	}
}
