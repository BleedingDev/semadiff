ivElement,\\n  Carousel.IndicatorGroupProps\\n>(function CarouselIndicators(props, ref) {\\n  return <Carousel.IndicatorGroup ref={ref} {...props} />\\n})\\n\\nexport const CarouselItem = React.forwardRef<\\n  HTMLDivElement,\\n  Carousel.ItemProps & { src?: string; alt?: string }\\n>(function CarouselItem({ src, alt, children, ...rest }, ref) {\\n  return (\\n    <Carousel.Item {...rest} ref={ref}>\\n      {src ? (\\n        <Image\\n          src={src}\\n          alt={alt}\\n          w=\\\"full\\\"\\n          h=\\\"300px\\\"\\n          objectFit=\\\"cover\\\"\\n          borderRadius=\\\"md\\\"\\n        />\\n      ) : (\\n        children\\n      )}\\n    </Carousel.Item>\\n  )\\n})\\n\\nconst AutoplayIcon = () => {\\n  const [running, setRunning] = React.useState(true)\\n  const toggle = () => setRunning(!running)\\n  return <Box onClick={toggle}>{running ? <LuPause /> : <LuPlay />}</Box>\\n}\\n\\nexport const CarouselItemGroup = Carousel.ItemGroup\\nexport const CarouselIndicator = Carousel.Indicator\\nexport const CarouselPrevTrigger = Carousel.PrevTrigger\\nexport const CarouselNextTrigger = Carousel.NextTrigger\\nexport const CarouselAutoplayTrigger = Carousel.AutoplayTrigger\\n\"","tokens":[{"start":4,"end":13,"priority":0,"foreground":"#9CDCFE"},{"start":15,"end":16,"priority":0,"foreground":"#CE9178"},{"start":16,"end":18,"priority":0,"foreground":"#D7BA7D"},{"start":18,"end":28,"priority":0,"foreground":"#CE9178"},{"start":28,"end":34,"priority":0,"foreground":"#D7BA7D"},{"start":34,"end":59,"priority":0,"foreground":"#CE9178"},{"start":59,"end":61,"priority":0,"foreground":"#D7BA7D"},{"start":61,"end":77,"priority":0,"foreground":"#CE9178"},{"start":77,"end":81,"priority":0,"foreground":"#D7BA7D"},{"start":81,"end":120,"priority":0,"foreground":"#CE9178"},{"start":120,"end":122,"priority":0,"foreground":"#D7BA7D"},{"start":122,"end":138,"priority":0,"foreground":"#CE9178"},{"start":138,"end":142,"priority":0,"foreground":"#D7BA7D"},{"start":142,"end