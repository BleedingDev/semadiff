+          knob: 'select',
+          defaultValue: 'blue',
+          options: ['blue', 'red', 'green'],
+        },
+        markColor: {
+          knob: 'select',
+          defaultValue: 'blue',
+          options: ['blue', 'red', 'green'],
+        },
+      }}
+      renderDemo={(props) => (
+        <PieChart
+          series={[
+            {
+              data,
+            },
+          ]}
+          height={200}
+          width={200}
+          slotProps={{
+            legend: {
+              sx: {
+                fontSize: props.fontSize,
+                color: props.color,
+                [`.${labelMarkClasses.fill}`]: {
+                  fill: props.markColor,
+                },
+              },
+            },
+          }}
+        />
+      )}
+      getCode={({ props }) => {
+        return `import { PieChart } from '@mui/x-charts/PieChart';
+import { labelMarkClasses } from '@mui/x-charts/ChartsLabel';
+
+<PieChart
+  {/** ... */}
+  slotProps={{
+    legend: {
+      sx: {
+        fontSize: ${props.fontSize},
+        color: ${props.color},
+        [\`.\${labelMarkClasses.fill}\`]: {
+          fill: ${props.markColor},
+        },
+      },
+    },
+  }}
+/>
+`;
+      }}
+    />
+  );
+}
