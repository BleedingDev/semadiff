+          knob: 'number',
+          defaultValue: 75,
+          step: 1,
+          min: 0,
+          max: 100,
+        },
+        fontSize: {
+          knob: 'number',
+          defaultValue: 40,
+          step: 1,
+          min: 5,
+          max: 50,
