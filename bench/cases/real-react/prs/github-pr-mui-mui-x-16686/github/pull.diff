+          series={series}
+          height={300}
+          xAxis={[
+            {
+              scaleType: 'band',
+              dataKey: 'year',
+              // @ts-expect-error, issue with band scale types
+              categoryGapRatio: props.categoryGapRatio,
+              barGapRatio: props.barGapRatio,
+            },
