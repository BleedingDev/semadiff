+          defaultValue: 0,
+          step: 1,
+          min: -100,
+          max: 100,
+        },
+      }}
+      renderDemo={(props) => (
+        <Box
+          sx={{
+            width: '100%',
+            height: 200,
+            margin: 'auto',
+            mb: 4,
+          }}
+        >
+          <Gauge
+            startAngle={-110}
+            endAngle={110}
+            sx={{
+              [`& .${gaugeClasses.valueText}`]: {
+                fontSize: props.fontSize,
+                transform: `translate(${props.dx}px, ${props.dy}px)`,
+              },
+            }}
+            value={props.value}
+            text={({ value, valueMax }) => `${value} / ${valueMax}`}
+          />
+        </Box>
