diff --git a/website/styles/machines/dialog.css b/website/styles/machines/dialog.css
new file mode 100644
index 0000000000..9c526cd6a5
--- /dev/null
+++ b/website/styles/machines/dialog.css
@@ -0,0 +1,80 @@
+.dialog {
+  &[data-scope="dialog"][data-part="trigger"],
+  &[data-scope="dialog"][data-part="description"] + div > button {
+    display: inline-flex;
+    align-items: center;
+    justify-content: center;
+    text-align: start;
+    cursor: pointer;
+    font-weight: 500;
+    padding-inline: 1rem;
+    padding-block: 0.25rem;
+    background: var(--colors-bg-primary-subtle);
+    color: #ffffff;
+  }
+
+  &[data-scope="dialog"][data-part="description"] + div > button:hover {
+    background: var(--colors-bg-primary-bold);
+  }
+
+  &[data-scope="dialog"][data-part="backdrop"] {
+    position: fixed;
+    inset: 0px;
+    background: rgba(0, 0, 0, 0.48);
+    z-index: 1400;
+  }
+
+  &[data-scope="dialog"][data-part="positioner"] {
+    display: flex;
+    align-items: center;
+    justify-content: center;
+    height: 100vh;
+    width: 100vw;
+    position: fixed;
+    z-index: 1400;
+    inset: 0px;
+  }
+
+  &[data-scope="dialog"][data-part="content"] {
+    width: 100%;
+    max-width: 400px;
+    border-radius: 0.375rem;
+    background: var(--colors-bg-subtle);
+    padding: 1.25rem;
+    position: relative;
+    pointer-events: auto;
+  }
+
+  &[data-scope="dialog"][data-part="title"] {
+    font-weight: 500;
+    font-size: 1.125rem;
+    margin-bottom: 0.5rem;
+  }
+
+  &[data-scope="dialog"][data-part="description"] {
+    font-size: 0.875rem;
+    margin-bottom: 0.75rem;
