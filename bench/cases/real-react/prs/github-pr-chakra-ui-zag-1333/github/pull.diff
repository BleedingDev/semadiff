diff --git a/website/styles/machines/collapsible.css b/website/styles/machines/collapsible.css
new file mode 100644
index 0000000000..a36fa24bbc
--- /dev/null
+++ b/website/styles/machines/collapsible.css
@@ -0,0 +1,61 @@
+[data-scope="collapsible"][data-part="root"] {
+  display: flex;
+  align-items: start;
+  flex-direction: column;
+  gap: 0.5rem;
+  width: 400px;
+}
+
+[data-scope="collapsible"][data-part="trigger"] {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  text-align: start;
+  cursor: pointer;
+  font-weight: 500;
+  padding-inline: 1rem;
+  padding-block: 0.25rem;
+  background: var(--colors-bg-primary-subtle);
+  color: #ffffff;
+}
+
+[data-scope="collapsible"][data-part="trigger"]:hover {
+  background: var(--colors-bg-primary-bold);
+}
+
+[data-scope="collapsible"][data-part="content"] {
+  display: flex;
+  flex-direction: column;
+  gap: 0.5rem;
+  overflow: hidden;
+}
+
+[data-scope="collapsible"][data-part="content"][data-state="open"] {
+  animation: open 110ms cubic-bezier(0, 0, 0.38, 0.9);
+}
+
+[data-scope="collapsible"][data-part="content"][data-state="closed"] {
+  animation: close 110ms cubic-bezier(0, 0, 0.38, 0.9);
+}
+
+@keyframes open {
+  from {
+    height: 0;
+    opacity: 0.01;
+  }
+  to {
+    height: var(--height);
+    opacity: 1;
+  }
+}
+
+@keyframes close {
+  from {
+    height: var(--height);
+    opacity: 1;
+  }
+  to {
+    height: 0;
+    opacity: 0.01;
+  }
+}
