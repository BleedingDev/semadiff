{
	"name": "semadiff",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "pnpm -r build",
		"benchmark:compare": "pnpm --filter @semadiff/benchmark-harness build && node packages/benchmark-harness/dist/cli.js --cases bench/cases/gold/micro --tools semadiff,git-diff,git-diff-color-moved,difftastic",
		"benchmark:compare:sem": "pnpm --filter @semadiff/benchmark-harness build && SEM_BIN=tmp/sem-install/bin/sem node packages/benchmark-harness/dist/cli.js --cases bench/cases/gold/micro --tools semadiff,sem",
		"benchmark:gold": "pnpm --filter @semadiff/benchmark-harness build && node packages/benchmark-harness/dist/cli.js --cases bench/cases/gold/micro",
		"benchmark:real:compare": "pnpm --filter @semadiff/benchmark-harness build && node packages/benchmark-harness/dist/cli.js --cases bench/cases/real/prs --tools semadiff,git-diff,git-diff-color-moved,difftastic,semanticdiff",
		"benchmark:real:refresh": "pnpm --filter @semadiff/benchmark-harness build && node scripts/refresh-real-pr-corpus.mjs",
		"dev": "pnpm --filter @semadiff/github-extension dev",
		"lint": "ultracite check .",
		"lint:fix": "ultracite fix .",
		"format": "oxfmt --config .oxfmtrc.jsonc --ignore-path .prettierignore .",
		"format:check": "oxfmt --config .oxfmtrc.jsonc --ignore-path .prettierignore --check .",
		"prepare": "bun scripts/setup-hooks.mjs",
		"typecheck": "tsc -b",
		"typecheck:app": "pnpm --filter pr-viewer typecheck",
		"test": "vitest run",
		"test:app": "pnpm --filter pr-viewer test",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "node scripts/run-with-colors.mjs playwright test",
		"publint": "node scripts/publint.mjs",
		"effect:v4:readiness": "node scripts/effect-v4-readiness.mjs",
		"compare:semanticdiff-lines": "bun scripts/compare-semanticdiff-lines.mjs",
		"quality": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm typecheck:app && pnpm test:coverage && pnpm test:app"
	},
	"dependencies": {
		"@tree-sitter-grammars/tree-sitter-markdown": "^0.3.2",
		"@tree-sitter-grammars/tree-sitter-yaml": "^0.7.1"
	},
	"devDependencies": {
		"@effect/vitest": "4.0.0-beta.5",
		"@playwright/test": "^1.48.0",
		"@rslib/core": "^0.19.6",
		"@types/node": "^20.14.15",
		"@vitest/coverage-v8": "^3.2.4",
		"effect": "4.0.0-beta.5",
		"oxfmt": "0.36.0",
		"oxlint": "1.51.0",
		"publint": "^0.3.17",
		"tree-sitter-cli": "^0.26.3",
		"typescript": "^5.6.3",
		"ultracite": "^7.2.5",
		"vitest": "^3.2.4"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@parcel/watcher",
			"@swc/core",
			"esbuild",
			"msgpackr-extract",
			"tree-sitter",
			"tree-sitter-cli",
			"tree-sitter-css",
			"tree-sitter-javascript",
			"tree-sitter-markdown",
			"tree-sitter-toml",
			"tree-sitter-typescript",
			"tree-sitter-yaml"
		]
	}
}
